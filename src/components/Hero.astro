---

import '../styles/global.css';
import { Icon } from 'astro-icon/components'


---

<section class="py-12">
    <div class="grid grid-cols-1 sm:grid-cols-5 gap-4 w-full max-w-5xl mx-auto p-4 sm:p-0">
        <div class="col-span-1 sm:col-span-3 sm:row-span-3 rounded-3xl flex justify-center items-center h-full bg-primary shadow-md min-h-[150px] p-4">
            <div class="inline-block text-center text-white">
                <h1 class="text-3xl font-bold mb-5">Hola! Soy <span class="text-orange-400 drop-shadow-[0_0_6px_rgba(251,146,60,0.45)]">alexceend</span></h1>
                <p class="text-m">Estudiante de 3º de <span class="font-bold text-orange-300">Ingeniería de Software en la Universidad Politécnica de Madrid</span>.
                Ambicioso e inquieto por descubrir nuevas tecnologías y desarrollar soluciones software</p>
            </div>
        </div>
        <div class="col-span-1 sm:col-span-2 sm:col-start-4 rounded-3xl flex justify-center items-center h-full bg-theme-beige min-h-[100px]">
            <div class="inline-block rotate-4 hover:-rotate-4 transition-transform">
                <a href="https://github.com/alexceend" target="_blank" class="flex items-center space-x-2"> 
                    <Icon name='github'/>
                    <span>My github !</span>
                </a>
            </div>
        </div>
        <div class="col-span-1 sm:col-span-2 sm:col-start-4 sm:row-start-2 rounded-3xl flex justify-center items-center h-full bg-theme-light-blue min-h-[100px]">
            <div class="inline-block -rotate-4 hover:rotate-4 transition-transform">
                <a href="mailto:alexceend@gmail.com" target="_blank" class="flex items-center space-x-2"> 
                    <Icon name='email'/>
                    <span>Email me !</span>
                </a>
            </div>
        </div>
        <div class="col-span-1 sm:col-span-2 sm:col-start-4 sm:row-start-3 rounded-3xl flex justify-center items-center h-full bg-theme-beige min-h-[100px]">
            <div class="inline-block rotate-4 hover:-rotate-4 transition-transform">
                <a href="https://www.linkedin.com/in/alejandro-cendoya-ramiro-243016365/" target="_blank" class="flex items-center space-x-2"> 
                    <Icon name='linkedin'/>
                    <span>Contact me !</span>
                </a>
            </div>
        </div>
    </div>    
</section>
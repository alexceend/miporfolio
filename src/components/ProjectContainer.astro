---
import Project from '../components/Project.astro';

import '../styles/global.css';

const images_catchemall = [
	"/miporfolio/catchemall-1.webp",
	"/miporfolio/catchemall-2.webp",
	"/miporfolio/catchemall-3.webp"
]

const images_danny = [
	"/miporfolio/danny-1.webp",
	"/miporfolio/danny-2.webp"
]

const images_nvim = [
	"/miporfolio/minevim.webp"
]

const images_dana = [
	"/miporfolio/dana-1.webp",
	"/miporfolio/dana-2.webp"
]

const images_unfollowers_insta = [
	"/miporfolio/unfollowers-1.webp",
	"/miporfolio/unfollowers-2.webp"
]

const images_solomo = [
	"/miporfolio/solomo-1.jpg"
]
const images_esteganografia = [
	"/miporfolio/esteganografia-1.webp"
]

const images_jojobird = [
	"/miporfolio/jojobird-1.webp",
	"/miporfolio/jojobird-2.webp"
]


const cats_spikes = [
    "/miporfolio/cats-spikes-1.webp",
    "/miporfolio/cats-spikes-2.webp"
]

const question_mark = [
    "/miporfolio/question-mark.webp"
]

---
<section>
    <div class = "justify-center  max-w-5xl m-auto flex flex-col mt-10 border bg-primary text-bold rounded-3xl py-4 text-white">
        <h1 class="text-5xl text-center font-bold">
             <span class="text-orange-400 drop-shadow-[0_0_6px_rgba(251,146,60,0.45)]">&lt;/&gt;</span> 
                Proyectos
             <span class="text-orange-400 drop-shadow-[0_0_6px_rgba(251,146,60,0.45)]">&lt;/&gt;</span>
        </h1>
        <p class="text-s text-center mt-2">
            Algunos proyectos que creé desde el 2019...
        </p>
    </div>
    <div class="grid grid-cols-2 grid-rows-[auto_auto_auto] sm:grid-cols-1 gap-4 w-full items-stretch max-w-7xl mx-auto">
        <div class="flex col-span-2 sm:col-span-1 row-span-1 gap-4 justify-center items-stretch">
            <Project title="Catch'em all. Fishingrod" image_paths={images_catchemall} 
            description="Un juego simple en unity sobre pesca para experimentar con motores de creación de videojuegos"
            year="2025" 
            link="https://github.com/alexceend/UnityFishingGame"/>
            <Project title="NVIM PLUGINS" image_paths={images_nvim} 
            description="Plugins para Nvim hechos en lua para customizar mi Arch - Linux" 
            year="2025"
            link="https://github.com/alexceend/nvim-plugins"
            />
        </div>
        <div class="flex col-span-2 sm:col-span-1 row-span-1 gap-4 justify-center items-stretch">
            <Project title="Danny's frog" image_paths={images_danny} 
            description="Videojuego hecho en java para experimentar con Swing"
            year="2024" 
            link="https://github.com/alexceend/Danny-s-frog"/>
            <Project title="Jojo bird" image_paths={images_jojobird} 
                description="Videojuego hecho en java junto a 2 compañeros para una Game JAM de la universidad." 
                year="2024"
                link="https://github.com/alexceend/jojo-bird"
                class = ""
            />
        </div>
        <div class="flex col-span-2 sm:col-span-1 row-span-1 gap-4 justify-center items-stretch">
            <Project title="Dana database" image_paths={images_dana} 
            description="Base de datos SQL simple que contiene información relevante sobre la DANA of Valencia. Incluyendo puntos de entrega de ayudas, páginas web de información y ayuda y las poblaciones y ciudades afectadas" 
            year="2025"
            link="https://github.com/alexceend/dana-data-base"
            class = ""
            />
            <Project title="Solomillo Mus Counter" image_paths={images_solomo}
            description="Aplicación Android Kotlin para contar los puntos del juego de cartas 'Mus'"
            year="2025"
            link="https://github.com/alexceend/solomillo-mus-counter"
            class = ""
            />
        </div>
        <div class="flex col-span-2 sm:col-span-1 row-span-1 gap-4 justify-center items-stretch">
            <Project title="Unfollowers Insta" image_paths={images_unfollowers_insta}
            description="Python script that lets you see the people that unfollowed you. (2024)" link="https://github.com/alexceend/see-who-unfollowed-you-insta"
            class = ""
            />
            <Project title="Esteganografía Java" image_paths={images_esteganografia}
            description="A simple java program that lets you hide text inside bmp images using esteganography. (2023)" link="https://github.com/alexceend/EsteganografiaJava"
            class = ""
            />
        </div>
        <div class="flex col-span-2 sm:col-span-1 row-span-1 gap-4 justify-center items-stretch">
            <Project title="Cats and spikes" image_paths={cats_spikes}
            description="Simple godot videogame that I did back in 2019." link="https://github.com/alexceend/Cats-Spikes"
            class = ""
            />
            <Project title="Upcoming projects" image_paths={question_mark}
            description="Upcoming projects..." link="https://github.com/alexceend"
            class = ""
            />
        </div>
    </div>
</section>
